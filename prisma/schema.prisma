generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DaireSahibi {
  id             String             @id @default(cuid())
  ad             String
  soyad          String
  tcKimlik       String?            @unique
  telefon        String
  email          String?
  notlar         String?
  sifre          String?
  tip            String             @default("Bireysel")
  vergiNo        String?            @unique
  unvan          String?
  olusturmaTar   DateTime           @default(now())
  konutlar       Konut[]
  sahiplikler    DaireSahipligi[]
  bakimYorumlari BakimTalebiYorum[]
  belgeler       Belge[]
}

model DaireSahipligi {
  id            String       @id @default(cuid())
  konutId       String
  konut         Konut        @relation(fields: [konutId], references: [id], onDelete: Cascade)
  daireSahibiId String
  daireSahibi   DaireSahibi  @relation(fields: [daireSahibiId], references: [id], onDelete: Cascade)
  alisTarihi    DateTime
  satisTarihi   DateTime?
  alisFiyati    Float?
  satisFiyati   Float?
  ipotekli      Boolean      @default(false)
  pay           Int?
  payda         Int?
  notlar        String?
  olusturmaTar  DateTime     @default(now())

  @@index([konutId])
  @@index([daireSahibiId])
  @@index([alisTarihi])
}

model Konut {
  id             String        @id @default(cuid())
  blok           String
  katNo          Int
  daireNo        String        @unique
  tip            String
  metrekare      Float
  kiraBedeli     Float
  durum          String        @default("Bos")
  ozellikler     String?
  etap           Int           @default(1)
  daireSahibiId  String?
  daireSahibi    DaireSahibi?  @relation(fields: [daireSahibiId], references: [id])
  olusturmaTar   DateTime      @default(now())
  sahiplikler    DaireSahipligi[]
  sozlesmeler    Sozlesme[]
  bakimTalepleri BakimTalebi[]
  belgeler       Belge[]
}

model Ogrenci {
  id             String        @id @default(cuid())
  ad             String
  soyad          String
  tcKimlik       String        @unique
  ogrenciNo      String?
  universite     String?
  bolum          String?
  telefon        String
  email          String        @unique
  acilKisi       String?
  acilTelefon    String?
  notlar         String?
  sifre          String?
  olusturmaTar   DateTime      @default(now())
  rol            String        @default("Aktif")
  sozlesmeler    Sozlesme[]
  bakimTalepleri BakimTalebi[]
}

model Sozlesme {
  id              String   @id @default(cuid())
  sozlesmeNo      String   @unique
  konutId         String
  konut           Konut    @relation(fields: [konutId], references: [id])
  ogrenciId       String
  ogrenci         Ogrenci  @relation(fields: [ogrenciId], references: [id])
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  aylikKira       Float
  depozito        Float
  kiraOdemGunu    Int      @default(1)
  ozelSartlar     String?
  durum           String   @default("Aktif")
  imzaTarihi      DateTime @default(now())
  olusturmaTar    DateTime @default(now())
  odemeler        Odeme[]
}

model Odeme {
  id           String   @id @default(cuid())
  sozlesmeId   String
  sozlesme     Sozlesme @relation(fields: [sozlesmeId], references: [id])
  tutar        Float
  tip          String
  odenmeTarihi DateTime
  aciklama     String?
  olusturmaTar DateTime @default(now())
}

model Tedarikci {
  id           String   @id @default(cuid())
  ad           String
  telefon      String
  email        String?
  kategori     String
  notlar       String?
  olusturmaTar DateTime @default(now())
}

model Gider {
  id           String   @id @default(cuid())
  baslik       String
  tutar        Float
  kategori     String
  tarih        DateTime
  aciklama     String?
  olusturmaTar DateTime @default(now())
}

model BakimTalebi {
  id            String             @id @default(cuid())
  baslik        String
  aciklama      String
  durum         String             @default("Bekliyor")
  oncelik       String             @default("Normal")
  olusturmaTar  DateTime           @default(now())
  tamamlanmaTar DateTime?
  ogrenciId     String
  ogrenci       Ogrenci            @relation(fields: [ogrenciId], references: [id])
  konutId       String
  konut         Konut              @relation(fields: [konutId], references: [id])
  yorumlar      BakimTalebiYorum[]
}

model BakimTalebiYorum {
  id            String       @id @default(cuid())
  icerik        String
  yazarTip      String       // "Admin" | "EvSahibi"
  yazarId       String
  yazarAd       String
  olusturmaTar  DateTime     @default(now())
  bakimTalebiId String
  bakimTalebi   BakimTalebi  @relation(fields: [bakimTalebiId], references: [id])
  daireSahibiId String?
  daireSahibi   DaireSahibi? @relation(fields: [daireSahibiId], references: [id])
}

model Belge {
  id            String      @id @default(cuid())
  ad            String
  tip           String      @default("Diger")
  dosyaYolu     String
  olusturmaTar  DateTime    @default(now())
  yukleyenTip   String      // "Admin" | "EvSahibi"
  yukleyenId    String
  konutId       String
  konut         Konut       @relation(fields: [konutId], references: [id])
  daireSahibiId String?
  daireSahibi   DaireSahibi? @relation(fields: [daireSahibiId], references: [id])
}

model KullaniciIzin {
  id           String   @id @default(cuid())
  kullaniciTip String   // "Kiraci" | "EvSahibi"
  kullaniciId  String
  izinler      String   // JSON: { sayfalar: string[], eylemler: string[] }
  guncelleTar  DateTime @default(now())

  @@unique([kullaniciTip, kullaniciId])
}

model Duyuru {
  id       String   @id @default(cuid())
  baslik   String
  icerik   String
  tarih    DateTime @default(now())
  hedef    String   @default("Tumu")
  yayinda  Boolean  @default(true)
}

model Senaryo {
  id            String   @id @default(cuid())
  ad            String
  aciklama      String?
  hedefModel    String
  tetikleyici   String?
  aktif         Boolean  @default(true)
  olusturanId   String?
  olusturanAd   String?
  olusturmaTar  DateTime @default(now())
  adimlar       SenaryoAdim[]
  akislar       SenaryoAkisi[]
  @@index([hedefModel])
  @@index([aktif])
}
model SenaryoAdim {
  id           String   @id @default(cuid())
  senaryoId    String
  senaryo      Senaryo  @relation(fields: [senaryoId], references: [id], onDelete: Cascade)
  sira         Int
  ad           String
  aciklama     String?
  panel        String
  rol          String?
  aksiyon      String
  sartFieldYol String?
  olusturmaTar DateTime @default(now())
  akisAdimlari SenaryoAkisiAdim[]
  @@index([senaryoId, sira])
}
model SenaryoAkisi {
  id             String   @id @default(cuid())
  senaryoId      String
  senaryo        Senaryo  @relation(fields: [senaryoId], references: [id])
  baslik         String
  hedefModel     String
  hedefId        String?
  durum          String   @default("Aktif")
  baslayanId     String?
  baslayanAd     String?
  aktifSira      Int      @default(1)
  baslamaTar     DateTime @default(now())
  bitirmeTar     DateTime?
  notlar         String?
  adimlar        SenaryoAkisiAdim[]
  @@index([durum])
  @@index([senaryoId])
  @@index([hedefModel, hedefId])
}
model SenaryoAkisiAdim {
  id                String    @id @default(cuid())
  akisId            String
  akis              SenaryoAkisi @relation(fields: [akisId], references: [id], onDelete: Cascade)
  adimId            String
  adim              SenaryoAdim  @relation(fields: [adimId], references: [id])
  sira              Int
  durum             String    @default("Beklemede")
  yapanKullaniciId  String?
  yapanAd           String?
  yapanPanel        String?
  yapilanTar        DateTime?
  notlar            String?
  olusturmaTar      DateTime  @default(now())
  @@index([akisId, sira])
  @@index([durum])
}
